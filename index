<!DOCTYPE html>
<html>
<head>
  <title>Splunk Dashboard Demo Portal</title>

  <style>
    body {
      font-family: Arial, sans-serif;
      background: #0b0f14;
      color: white;
      padding: 40px;
    }

    h1 {
      margin-bottom: 10px;
    }

    p {
      color: #b8c0cc;
    }

    .card {
      background: #161b22;
      border: 1px solid #30363d;
      border-radius: 12px;
      padding: 20px;
      margin-top: 20px;
      max-width: 750px;
    }

    a {
      color: #4ea1ff;
      text-decoration: none;
      font-size: 22px;
      font-weight: bold;
    }

    a:hover {
      text-decoration: underline;
    }
  </style>
</head>

<body>

  <h1>Splunk Dashboard Demo Portal</h1>

  <p>
    Select a dashboard demo below.
  </p>

  <div class="card">
    <a href="./fraud-demo/">
      Fraud Detection Dashboard
    </a>

    <p>
      Sample dashboard showing fraud monitoring and investigation workflows.
    </p>
  </div>

  <div class="card">
    <a href="./soc-maturity/">
      SOC Maturity Dashboard
    </a>

    <p>
      Sample dashboard showing SOC operational maturity and resilience metrics.
    </p>
  </div>

</body>
</html>
